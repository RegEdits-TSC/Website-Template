# Copy to .env for local development. NEVER commit a real .env.
# All values are validated at startup; a missing/invalid value fails boot.

# HTTP
PORT=8080

# PostgreSQL - use sslmode=verify-full with a pinned CA in production.
DATABASE_URL=postgres://app:CHANGEME@localhost:5432/dino?sslmode=disable

# Session + CSRF signing keys (generate with: openssl rand -base64 32)
SESSION_KEY=
CSRF_KEY=

# WebAuthn / passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:8080

# OIDC (social login) - optional
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
