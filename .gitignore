# Binaries
/bin/
/out/
*.exe
*.dll
*.so
*.dylib

# Test / coverage
*.test
*.out
coverage.*

# Go workspace
go.work
go.work.sum

# Secrets and local env - never commit these
.env
.env.*
!.env.example
*.pem
*.key
secrets.*

# Key bundles / keystores (binary; not caught by detect-private-key or gitleaks)
*.p12
*.pfx
*.jks
*.keystore
*.der

# SSH private keys (often extension-less)
id_rsa
id_dsa
id_ecdsa
id_ed25519
*_rsa
*_ed25519

# Build / SBOM / scan artifacts
sbom.spdx.json
trivy.sarif
results.sarif
/dist/

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
